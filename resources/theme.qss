/*
    VS Code Dark+ inspired theme for claude-chats-browser.

    Palette (from VS Code's Dark+ default):
      editor background   #1E1E1E
      panel background    #252526
      widget background   #333333
      border              #3C3C3C
      foreground          #D4D4D4
      muted foreground    #858585
      selection           #264F78
      hover               #2A2D2E
      keyword blue        #569CD6   (You / human)
      type teal           #4EC9B0   (Claude / assistant)
      comment green       #6A9955   (thinking)
      function yellow     #DCDCAA   (tool call)
      string orange       #CE9178   (tool result / code)
      link blue           #3794FF
*/

QWidget {
    background-color: #1E1E1E;
    color: #D4D4D4;
    font-size: 10pt;
}

QMainWindow, QMenuBar, QStatusBar {
    background-color: #252526;
}

QMenuBar::item:selected, QMenu::item:selected {
    background-color: #094771;
}

QMenu {
    background-color: #252526;
    border: 1px solid #3C3C3C;
}

QLineEdit {
    background-color: #3C3C3C;
    border: 1px solid #3C3C3C;
    border-radius: 4px;
    padding: 4px 6px;
    selection-background-color: #264F78;
}

QLineEdit:focus {
    border: 1px solid #007ACC;
}

QListView {
    background-color: #252526;
    border: none;
    outline: none;
}

QListView::item {
    padding: 5px 8px;
}

QListView::item:hover {
    background-color: #2A2D2E;
}

QListView::item:selected {
    background-color: #094771;
    color: #FFFFFF;
}

QSplitter::handle {
    background-color: #3C3C3C;
}

QScrollBar:vertical {
    background-color: #1E1E1E;
    width: 14px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background-color: #424242;
    min-height: 24px;
    border-radius: 3px;
}

QScrollBar::handle:vertical:hover {
    background-color: #4F4F4F;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QToolButton {
    color: #D4D4D4;
    padding: 2px;
}

/* Reader */

#readerContainer {
    background-color: #1E1E1E;
}

#readerPlaceholder {
    color: #858585;
    font-style: italic;
    padding: 40px;
}

#senderHuman {
    color: #569CD6;
    font-weight: bold;
}

#senderAssistant {
    color: #4EC9B0;
    font-weight: bold;
}

#messageText {
    color: #D4D4D4;
}

#messageDivider {
    color: #3C3C3C;
    max-height: 1px;
}

#thinkingBody {
    color: #6A9955;
    background-color: #232323;
    border-left: 2px solid #6A9955;
    padding: 6px 10px;
}

#toolBody {
    color: #CE9178;
    background-color: #232323;
    border-left: 2px solid #DCDCAA;
    padding: 6px 10px;
    font-family: "Cascadia Code", "Consolas", monospace;
}
